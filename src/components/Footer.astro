---
import Brand from './Brand.astro';
import { footerGroups } from '@/data/site';
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <div class="footer-brand">
        <div class="footer-brand__logo">
          <Brand />
        </div>
        <p>聊出你的产品</p>
      </div>

      <div class="footer-link-groups">
        {footerGroups.map((group) => (
          <section class="footer-link-panel">
            <h3>{group.title}</h3>
            {group.links.map((link) => (
              link.href === '#'
                ? <span>{link.label}</span>
                : <a href={link.href} target="_blank" rel="noopener noreferrer nofollow">{link.label}</a>
            ))}
          </section>
        ))}
      </div>
    </div>

    <div class="site-footer__legal">
      <p>2026 superun Inc. All rights reserved.</p>
      <div class="site-footer__legal-links">
        <a href="https://beian.miit.gov.cn" target="_blank" rel="noopener noreferrer nofollow">浙ICP备2024098187号</a>
        <a href="https://beian.mps.gov.cn/#/query/webSearch?code=33010602014354" target="_blank" rel="noopener noreferrer nofollow">浙公网安备33010602014354号</a>
      </div>
    </div>
  </div>
</footer>
