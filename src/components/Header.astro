---
import Brand from './Brand.astro';
import LocaleMenu from './LocaleMenu.astro';
import { publicPageCopy } from '@/data/fidelity';

const copy = publicPageCopy['zh-CN'];
---

<header class="site-header">
  <div class="site-header__inner">
    <div class="header-brand-group">
      <Brand ariaLabel={copy.header.homeAria} />
      <LocaleMenu />
    </div>

    <nav class="header-actions" aria-label="主导航">
      <button class="header-action header-action--login" type="button" onclick="window.location.href='/web/login?redirectUrl=%2Fhome'" data-copy-key="header.login">{copy.header.login}</button>
    </nav>
  </div>
</header>
