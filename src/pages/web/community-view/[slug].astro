---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { publicPageCopy } from '@/data/fidelity';
import {
  homeTemplateByRouteSlug,
  homeTemplateRouteSlugs,
  parseWebsiteIntroduction,
} from '@/data/template-directory';

export const prerender = true;

export function getStaticPaths() {
  return homeTemplateRouteSlugs.map((slug) => ({
    params: { slug },
    props: { template: homeTemplateByRouteSlug[slug] },
  }));
}

const { template } = Astro.props;
const copy = publicPageCopy['zh-CN'];
const remixHref = `/web/login?redirectUrl=%2Fhome&prompt=${encodeURIComponent(`复刻 ${template.title}`)}`;
const previewSrc = template.visitUrl || `https://${template.previewSlug}.superun.yun`;
const narrativeBlocks = parseWebsiteIntroduction(template.websiteIntroduction);
const defaultDevice = template.deviceType === 'mobile' ? 'mobile' : 'desktop';
const titleMark = template.title.trim().charAt(0) || 'S';
const iconDesktop = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M13.334 2H2.66732C1.93094 2 1.33398 2.59695 1.33398 3.33333V10C1.33398 10.7364 1.93094 11.3333 2.66732 11.3333H13.334C14.0704 11.3333 14.6673 10.7364 14.6673 10V3.33333C14.6673 2.59695 14.0704 2 13.334 2Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M5.33398 14H10.6673" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M8 11.332V13.9987" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg>`;
const iconMobile = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M11.334 1.33203H4.66732C3.93094 1.33203 3.33398 1.92898 3.33398 2.66536V13.332C3.33398 14.0684 3.93094 14.6654 4.66732 14.6654H11.334C12.0704 14.6654 12.6673 14.0684 12.6673 13.332V2.66536C12.6673 1.92898 12.0704 1.33203 11.334 1.33203Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M8 12H8.00667" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>`;
const iconChevronDown = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4.5 6.25L8 9.75L11.5 6.25" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path></svg>`;
const iconRemix = `<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8.66797 2L10.1346 4.86667L13.3346 5.33333L11.0003 7.6L11.5346 10.8L8.66797 9.33333L5.8013 10.8L6.33464 7.6L4.0013 5.33333L7.2013 4.86667L8.66797 2Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path><path d="M3 13H13" stroke="currentColor" stroke-linecap="round"></path></svg>`;
---

<BaseLayout title={`${template.title} - 优势智设`} hideHeader hideFooter>
  <section class="community-runtime" data-community-root>
    <div class="community-runtime__group">
      <aside class="community-runtime__panel">
        <header class="community-runtime__panel-header">
          <button class="community-runtime__project" type="button" onclick="window.location.href='/home'">
            <span class="community-runtime__project-mark" aria-hidden="true">{titleMark}</span>
            <span class="community-runtime__project-label">{template.title}</span>
          </button>

          <button class="community-runtime__collapse" type="button" title="折叠面板" aria-label="折叠面板">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M10 13L5 8L10 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </button>
        </header>

        <div class="community-runtime__panel-body">
          <div class="community-runtime__narrative">
            <p class="community-runtime__lead">{template.description}</p>

            <div class="community-runtime__copy">
              {narrativeBlocks.map((block) => {
                if (block.type === 'heading') {
                  return (
                    <p class="community-runtime__copy-heading">
                      <strong>{block.text}</strong>
                    </p>
                  );
                }

                if (block.type === 'bullet') {
                  return (
                    <p class="community-runtime__copy-bullet">
                      {block.label ? <strong>{block.label}</strong> : null}
                      <span>{block.label ? ` - ${block.text}` : block.text}</span>
                    </p>
                  );
                }

                return <p class="community-runtime__copy-paragraph">{block.text}</p>;
              })}
            </div>

            {template.previewImage ? (
              <a class="community-runtime__panel-image-link" href={previewSrc} target="_blank" rel="noopener noreferrer">
                <img class="community-runtime__panel-image" src={template.previewImage} alt={`${template.title} 预览图`} loading="eager" decoding="async" />
              </a>
            ) : null}
          </div>

          <button class="community-runtime__remix" type="button" onclick={`window.location.href='${remixHref}'`} data-copy-key="community.recreate">
            <span set:html={iconRemix}></span>
            <span>{copy.community.recreate}</span>
          </button>
        </div>
      </aside>

      <div class="community-runtime__separator" aria-hidden="true"></div>

      <div class="community-runtime__preview">
        <div class="community-runtime__toolbar">
          <div class="community-runtime__device-switch" role="tablist" aria-label="预览设备">
            <button class={`community-runtime__device-button ${defaultDevice === 'mobile' ? 'is-active' : ''}`} type="button" data-device="mobile">
              <span set:html={iconMobile}></span>
              <span data-copy-key="community.mobile">{copy.community.mobile}</span>
            </button>
            <button class={`community-runtime__device-button ${defaultDevice === 'desktop' ? 'is-active' : ''}`} type="button" data-device="desktop">
              <span set:html={iconDesktop}></span>
              <span data-copy-key="community.desktop">{copy.community.desktop}</span>
            </button>
          </div>

          <button class="community-runtime__surface" type="button">
            <span>主页端</span>
            <span set:html={iconChevronDown}></span>
          </button>
        </div>

        <div class="community-runtime__canvas" data-device-host>
          <div class="community-runtime__frame">
            <iframe
              class="community-runtime__iframe"
              src={previewSrc}
              title={copy.community.previewAria}
              loading="eager"
              sandbox="allow-scripts allow-same-origin allow-popups allow-forms allow-modals allow-downloads"
              allow="clipboard-read; clipboard-write"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ defaultDevice }}>
    (() => {
      const root = document.querySelector('[data-community-root]');
      const deviceHost = document.querySelector('[data-device-host]');
      const deviceButtons = Array.from(document.querySelectorAll('[data-device]'));
      const collapseButton = document.querySelector('.community-runtime__collapse');

      const setDevice = (device) => {
        const nextDevice = device === 'mobile' ? 'mobile' : 'desktop';
        root?.setAttribute('data-device', nextDevice);
        deviceHost?.setAttribute('data-device', nextDevice);
        deviceButtons.forEach((button) => {
          if (!(button instanceof HTMLButtonElement)) return;
          button.classList.toggle('is-active', button.getAttribute('data-device') === nextDevice);
        });
      };

      deviceButtons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener('click', () => {
          setDevice(button.getAttribute('data-device') || 'desktop');
        });
      });

      if (collapseButton instanceof HTMLButtonElement) {
        collapseButton.addEventListener('click', () => {
          root?.classList.toggle('is-collapsed');
        });
      }

      setDevice(defaultDevice);
    })();
  </script>
</BaseLayout>
