      supportCards: [
        { title: '真人极速支持', description: '专属 HR 顾问通过聊天、邮件和电话提供服务。平均响应时间不到5分钟。', meta: '您的专属顾问' },
        { title: '原生集成', description: '即开即用对接 QuickBooks、Xero、Slack、BambooHR 等50多个工具。', meta: 'QB · Xero · Slack · GH · Okta' },
        { title: '专属保险顾问', description: '持牌保险经纪人帮您为团队找到最适合的方案和预算。', meta: 'Marcus Chen · 持牌福利顾问 · 在线中' },
        { title: '加密与安全', description: 'SOC 2 Type II 认证。AES-256 静态加密，TLS 1.3 传输加密。您的数据始终受到保护。', meta: 'SOC 2 Type II · AES-256 · GDPR · 99.99% 可用性' },
      ],
      closingTitle: '开始30天免费试用',
      closingPrimary: '免费试用 Nexus',
      closingSecondary: '联系专家',
      footerTagline: 'AI 原生的薪资、人力资源、福利和合规平台。为现代团队而生。',
      footerColumns: [
        { title: '产品', links: ['薪资管理', '福利保险', '合规管理', 'HR 平台', '集成', '定价'] },
        { title: '公司', links: ['关于我们', '招聘', '博客', '新闻', '联系我们'] },
        { title: '法律', links: ['隐私政策', '服务条款', '安全', 'Cookie 政策'] },
      ],
      footerCopy: '© 2026 Nexus. 保留所有权利。',
      footerSocial: ['Twitter', 'LinkedIn', 'GitHub'],
      marqueeLabel: '创始人 免费',
    }
  : null;

const localCommunityPreview = glowmindPreview ?? goosePreview ?? nexusPreview;
const iframePreviewSrc = !localCommunityPreview ? media?.communityPreviewSrc ?? media?.templatePageSrc ?? null : null;
const immersivePreview = Boolean(localCommunityPreview) || Boolean(iframePreviewSrc);
---

<BaseLayout title="superun - 优势智设" hideHeader hideFooter>
  <section class={`community-shell ${immersivePreview ? 'community-shell--immersive' : 'community-shell--local'}`.trim()}>
    {!immersivePreview ? (
      <div class="community-topbar">
        <div class="community-topbar__left">
          <div class="community-title-pill">
            <Brand compact className="community-title-pill__brand" ariaLabel={copy.header.homeAria} />
            <span class="community-title-pill__text">{template.title}</span>
          </div>
        </div>

        <div class="community-topbar__right">
          <a class="community-recreate-button community-recreate-button--topbar" data-copy-key="community.recreate" href={remixHref}>{copy.community.recreate}</a>
        </div>
      </div>
    ) : null}

    <div class={`community-stage ${immersivePreview ? 'community-stage--immersive' : 'community-stage--local'}`.trim()}>
      <div class={`community-stage__main ${immersivePreview ? 'community-stage__main--immersive' : 'community-stage__main--full'}`.trim()}>
        <div class="community-preview-shell community-preview-shell--immersive">
          <div class={`community-preview-frame ${localCommunityPreview ? 'community-preview-frame--local' : ''} ${immersivePreview ? 'community-preview-frame--immersive' : ''}`.trim()} id="preview-frame">
            {glowmindPreview ? (
              <article class="community-local community-local--glowmind">
                <header class="glowmind-nav">
                  <a class="glowmind-brand" href="#glowmind-hero">
                    <span class="glowmind-brand__mark">{glowmindPreview.brand.mark}</span>
                    <span>{glowmindPreview.brand.name}</span>
                  </a>
                  <nav class="glowmind-nav__links" aria-label="GlowMind navigation">
                    {glowmindPreview.navigation.map((item) => (
                      <a href={item.href}>{item.label}</a>
                    ))}
                    <a class="glowmind-nav__admin" href="/web/login?redirectUrl=%2Fhome">进入后台</a>
                  </nav>
                </header>

                <section class="glowmind-hero" id="glowmind-hero">
                  <div class="glowmind-hero__copy">
                    <span class="glowmind-eyebrow">{glowmindPreview.eyebrow}</span>
                    <h1>
                      <span>{glowmindPreview.titleLeading}</span>
                      <span>
                        {glowmindPreview.titlePrefix}
                        <em>{glowmindPreview.titleAccent}</em>
                      </span>
                    </h1>
                    <p>{glowmindPreview.description}</p>
                    <div class="glowmind-actions">
                      <a class="glowmind-button glowmind-button--primary" href={remixHref}>{glowmindPreview.primaryCta}</a>
                      <a class="glowmind-button glowmind-button--secondary" href="#features">{glowmindPreview.secondaryCta}</a>
                    </div>
                    <div class="glowmind-trustmarks">
                      {glowmindPreview.trustMarks.map((item) => (
                        <span>{item}</span>
                      ))}
                    </div>
                  </div>
                  <div class="glowmind-hero__visual">
                    <img src={glowmindPreview.heroImage} alt={glowmindPreview.heroImageAlt} loading="eager" decoding="async" />
                    <div class="glowmind-chat-card">
                      <span class="glowmind-chat-card__title">{glowmindPreview.chatTitle}</span>
                      <p class="glowmind-chat-card__question">{glowmindPreview.chatQuestion}</p>
                      <div class="glowmind-chat-card__answer">
                        <span>AI 建议回复</span>
                        <p>{glowmindPreview.chatAnswer}</p>
                      </div>
                      <div class="glowmind-chat-card__actions">
                        <button type="button">发送</button>
                        <button type="button">编辑</button>
                      </div>
                    </div>
                  </div>
                </section>

                <section class="glowmind-section" id="features">
                  <div class="glowmind-section__heading">
                    <span class="glowmind-section__eyebrow">Core Features</span>
                    <h2>每一个功能，都为美妆场景量身定制</h2>
                  </div>
                  <div class="glowmind-feature-grid">
                    {glowmindPreview.features.map((feature) => (
                      <article class="glowmind-feature-card">
                        <div class="glowmind-feature-card__top">
                          <span>{feature.index}</span>
                        </div>
                        <h3>{feature.title}</h3>
                        <p>{feature.description}</p>
                      </article>
                    ))}
                  </div>
                </section>

                <section class="glowmind-section glowmind-section--warm" id="scenarios">
                  <div class="glowmind-section__heading">
                    <span class="glowmind-section__eyebrow">Use Cases</span>
                    <h2>从品牌旗舰到新锐国货，都在用 GlowMind</h2>
                  </div>
                  <div class="glowmind-scenario-grid">
                    {glowmindPreview.scenarios.map((item) => (
                      <article class="glowmind-scenario-card">
                        <img src={item.image} alt={item.imageAlt} loading="lazy" decoding="async" />
                        <div class="glowmind-scenario-card__body">
                          <span>{item.eyebrow}</span>
                          <h3>{item.title}</h3>
                          <p>{item.description}</p>
                        </div>
                      </article>
                    ))}
                  </div>
                </section>

                <section class="glowmind-section glowmind-section--dark" id="data">
                  <div class="glowmind-section__heading glowmind-section__heading--center">
                    <span class="glowmind-section__eyebrow">Data Impact</span>
                    <h2>用数据证明 AI 的价值</h2>
                  </div>
                  <div class="glowmind-metric-grid">
                    {glowmindPreview.metrics.map((item) => (
                      <article class="glowmind-metric-card">
                        <strong>{item.value}</strong>
                        <span>{item.label}</span>
                        <p>{item.description}</p>
                      </article>
                    ))}
                  </div>
                </section>

                <section class="glowmind-section glowmind-segmentation" id="segmentation">
                  <div class="glowmind-segmentation__copy">
                    <span class="glowmind-section__eyebrow">Segmentation Logic</span>
                    <h2>{glowmindPreview.segmentationTitle}</h2>
                    <p>{glowmindPreview.segmentationDescription}</p>
                  </div>
                  <div class="glowmind-tier-list">
                    {glowmindPreview.tiers.map((item) => (
                      <article class="glowmind-tier-card">
                        <div class="glowmind-tier-card__label">{item.name}</div>
                        <div class="glowmind-tier-card__body">
                          <div class="glowmind-tier-card__meta">
                            <span>{item.rule}</span>
                            <strong>{item.percent}</strong>
                          </div>
                          <p>{item.detail}</p>
                        </div>
                      </article>
                    ))}
                  </div>
                </section>

                <section class="glowmind-section glowmind-section--cta">
                  <div class="glowmind-section__heading glowmind-section__heading--center">
                    <h2>{glowmindPreview.closingTitle}</h2>
                    <p>{glowmindPreview.closingDescription}</p>
                  </div>
                  <div class="glowmind-actions glowmind-actions--center">
                    <a class="glowmind-button glowmind-button--primary" href={remixHref}>{glowmindPreview.primaryCta}</a>
                    <button class="glowmind-button glowmind-button--secondary" type="button">{glowmindPreview.closingSecondary}</button>
                  </div>
                </section>

                <footer class="glowmind-footer">
                  <div class="glowmind-brand glowmind-brand--footer">
                    <span class="glowmind-brand__mark">{glowmindPreview.brand.mark}</span>
                    <span>{glowmindPreview.brand.name}</span>
                  </div>
                  <p>{glowmindPreview.footerCopy}</p>
                </footer>

                <a class="glowmind-built-with" href="https://www.superun.com">
                  <span>Built with</span>
                  <strong>superun</strong>
                  <span aria-hidden="true">×</span>
                </a>
              </article>
            ) : goosePreview ? (
              <article class="community-local community-local--goose">
                <aside class="goose-sidebar">
                  <a class="goose-brand" href="#goose-dashboard">
                    <span class="goose-brand__mark" aria-hidden="true"></span>
                    <span class="goose-brand__copy">
                      <strong>{goosePreview.brand.name}</strong>
                      <span>{goosePreview.brand.subtitle}</span>
                    </span>
                  </a>

                  <div class="goose-sidebar__sync">
                    <div class="goose-sidebar__sync-pill">
                      <span class="goose-sidebar__sync-dot" aria-hidden="true"></span>
                      <span>{goosePreview.syncLabel}</span>
                    </div>
                    <p>{goosePreview.syncMeta}</p>
                  </div>

                  <button class="goose-secondary-button goose-secondary-button--sidebar" type="button">{goosePreview.importLabel}</button>

                  <nav class="goose-sidebar__nav" aria-label="Goose Planet navigation">
                    {goosePreview.navigation.map((item) => (
                      <a class={`goose-nav-link ${item.active ? 'is-active' : ''}`.trim()} href={item.href}>
                        <span class={`goose-nav-link__icon goose-nav-link__icon--${item.icon}`.trim()} aria-hidden="true"></span>
                        <span>{item.label}</span>
                      </a>
                    ))}
                  </nav>

                  <p class="goose-sidebar__footer">Goose Planet © 2026</p>
                </aside>

                <div class="goose-main" id="goose-dashboard">
                  <header class="goose-appbar">
                    <div class="goose-appbar__brand">
                      <span class="goose-brand__mark" aria-hidden="true"></span>
                      <span class="goose-brand__copy">
                        <strong>{goosePreview.brand.name}</strong>
                        <span>{goosePreview.brand.subtitle}</span>
                      </span>
                    </div>
                    <span class="goose-appbar__metric">
                      <span class="goose-appbar__metric-dot" aria-hidden="true"></span>
                      <span>{goosePreview.brand.metric}</span>
                    </span>
                  </header>

                  <div class="goose-dashboard__header">
                    <div class="goose-dashboard__copy">
                      <h1>{goosePreview.greeting}</h1>
                      <p>{goosePreview.summary}</p>
                    </div>
                    <button class="goose-secondary-button goose-secondary-button--refresh" type="button">
                      <span>{goosePreview.refreshLabel}</span>
                    </button>
                  </div>

                  <section class="goose-insight-grid" aria-label="洞察摘要">
                    {goosePreview.insightCards.map((item) => (
                      <article class="goose-insight-card">
                        <div class="goose-insight-card__top">
                          <span>{item.label}</span>
                          <span class={`goose-insight-card__delta goose-insight-card__delta--${item.tone}`.trim()}>{item.delta}</span>
                        </div>
                        <strong>{item.value}</strong>
                        <p>{item.detail}</p>
                      </article>
                    ))}
                  </section>

                  <section class="goose-panel-grid">
                    <article class="goose-panel goose-panel--suggestions" id="goose-content">
                      <div class="goose-panel__header">
                        <h2>今日内容建议</h2>
                        <span>AI 推荐</span>
                      </div>
                      <div class="goose-suggestion-list">
                        {goosePreview.suggestions.map((item) => (
                          <article class="goose-suggestion-row">
                            <div class="goose-choice">
                              <span class="goose-choice__dot" aria-hidden="true"></span>
                              <div class="goose-suggestion-row__copy">
                                <strong>{item.title}</strong>
                                <span>
                                  {item.source}
                                  <em>{item.badge}</em>
                                </span>
                              </div>
                            </div>
                            <button class="goose-action-button" type="button">{item.action}</button>
                          </article>
                        ))}
                      </div>
                    </article>

                    <article class="goose-panel goose-panel--questions" id="goose-questions">
                      <div class="goose-panel__header goose-panel__header--questions">
                        <h2>最新客户提问</h2>
                        <a href="#goose-opportunities">全部 ›</a>
                      </div>
                      <div class="goose-filter-row">
                        {goosePreview.questionFilters.map((item, index) => (
                          <button class={`goose-filter-chip ${index === 0 ? 'is-active' : ''}`.trim()} type="button">{item}</button>
                        ))}
                      </div>
                      <div class="goose-question-list">
                        {goosePreview.questions.map((item) => (
                          <article class="goose-question-row">
                            <div class="goose-choice goose-choice--question">
                              <span class="goose-choice__dot" aria-hidden="true"></span>
                              <div class="goose-question-row__copy">
                                <strong>{item.text}</strong>
                                <span>{item.meta}</span>
                              </div>
                            </div>
                            <span class="goose-question-row__arrow" aria-hidden="true">↗</span>
                          </article>
                        ))}
                      </div>
                    </article>
                  </section>

                  <section class="goose-weekly" id="goose-opportunities">
                    <div class="goose-panel__header goose-panel__header--weekly">
                      <h2>本周经营建议</h2>
                    </div>
                    <div class="goose-weekly-grid">
                      {goosePreview.actions.map((item) => (
                        <article class="goose-weekly-card">
                          <span>{item.index}</span>
                          <h3>{item.title}</h3>
                          <p>{item.detail}</p>
                        </article>
                      ))}
                    </div>
                  </section>

                  <nav class="goose-mobile-tabs" aria-label="Goose Planet tabs">
                    {goosePreview.navigation.map((item) => (
                      <a class={`goose-mobile-tab ${item.active ? 'is-active' : ''}`.trim()} href={item.href}>
                        <span class={`goose-nav-link__icon goose-nav-link__icon--${item.icon}`.trim()} aria-hidden="true"></span>
                        <span>{item.mobileLabel}</span>
                      </a>
                    ))}
                  </nav>
                </div>

                <div class="goose-built-with" aria-label="Built with superun badge">
                  <span>Built with</span>
                  <strong>superun</strong>
                  <button type="button" aria-label="dismiss">×</button>
                </div>
              </article>
            ) : nexusPreview ? (
              <article class="community-local community-local--nexus">
                <header class="nexus-banner">{nexusPreview.banner}</header>

                <div class="nexus-nav-shell">
                  <nav class="nexus-nav" aria-label="Nexus navigation">
                    <a class="nexus-brand" href="#nexus-hero">
                      <span class="nexus-brand__mark">{nexusPreview.brand.mark}</span>
                      <span>{nexusPreview.brand.name}</span>
                    </a>
                    <div class="nexus-nav__links">
                      {nexusPreview.navigation.map((item) => (
                        <a href={item.href}>{item.label}</a>
                      ))}
                    </div>
                    <a class="nexus-nav__cta" href={remixHref}>开始使用</a>
                    <button class="nexus-nav__menu" type="button" aria-label="open menu">☰</button>
                  </nav>
                </div>

                <section class="nexus-hero" id="nexus-hero">
                  <div class="nexus-hero__copy">
                    <h1>
                      <span>{nexusPreview.heroIntro}</span>
                      {nexusPreview.heroTitle.map((line) => (
                        <span>{line}</span>
                      ))}
                    </h1>
                    <p>{nexusPreview.heroDescription}</p>
                    <div class="nexus-hero__actions">
                      <a class="nexus-button nexus-button--primary" href={remixHref}>{nexusPreview.heroPrimary}</a>
                    </div>
                    <span class="nexus-hero__meta">{nexusPreview.heroMeta}</span>
                  </div>
                </section>

                <section class="nexus-logo-strip" aria-label="trusted by logos">
                  {nexusPreview.logos.map((item) => (
                    <span>{item}</span>
                  ))}
                </section>

                <section class="nexus-proof">
                  <div class="nexus-proof__media"></div>
                  <article class="nexus-quote-card">
                    <h2>{nexusPreview.featured.title}</h2>
                    <p>{nexusPreview.featured.quote}</p>
                    <div class="nexus-quote-card__meta">
                      <strong>{nexusPreview.featured.author}</strong>
                      <span>{nexusPreview.featured.role}</span>
                    </div>
                    <a href="#nexus-testimonials">{nexusPreview.featured.cta}</a>
                  </article>
                </section>

                <section class="nexus-feature-list" id="nexus-features">
                  {nexusPreview.features.map((feature) => (
                    <section class="nexus-feature-row" id={`nexus-${feature.id}`}>
                      <div class="nexus-feature-row__copy">
                        <span>{feature.index}</span>
                        <h2>{feature.title}</h2>
                        <div class="nexus-chip-list">
                          {feature.bullets.map((item) => (
                            <button type="button">{item}</button>
                          ))}
                        </div>
                      </div>

                      <article class={`nexus-app-card nexus-app-card--${feature.id}`.trim()}>
                        <div class="nexus-app-card__top">
                          <strong>{feature.cardTitle}</strong>
                          <span>{feature.cardStatus}</span>
                        </div>

                        {'metricLabel' in feature && (
                          <div class="nexus-payroll-card__summary">
                            <p>{feature.metricLabel}</p>
                            <strong>{feature.metricValue}</strong>
                            <span>{feature.metricMeta}</span>
                          </div>
                        )}

                        {'people' in feature && feature.people && (
                          <div class="nexus-payroll-card__list">
                            {feature.people.map((person) => (
                              <div class="nexus-person-row">
                                <div class="nexus-person-row__profile">
                                  <span>{person.initials}</span>
                                  <div>
                                    <strong>{person.name}</strong>
                                    <small>{person.team}</small>
                                  </div>
                                </div>
                                <strong>{person.value}</strong>
                              </div>
                            ))}
                          </div>
                        )}

                        {'primary' in feature && feature.primary && !('secondary' in feature) && (
                          <button class="nexus-button nexus-button--danger" type="button">{feature.primary}</button>
                        )}

                        {'focusTitle' in feature && feature.stats && (
                          <div class="nexus-compliance-card">
                            <div class="nexus-compliance-card__focus">
                              <strong>{feature.focusTitle}</strong>
                              <span>{feature.focusMeta}</span>
                              <p>{feature.focusStatus}</p>
                            </div>
                            <div class="nexus-stat-grid">
                              {feature.stats.map((item) => (
                                <div>
                                  <strong>{item.value}</strong>
                                  <span>{item.label}</span>
                                </div>
                              ))}
                            </div>
                          </div>
                        )}

                        {'plans' in feature && feature.plans && (
                          <div class="nexus-benefits-card">
                            <div class="nexus-plan-list">
                              {feature.plans.map((plan) => (
                                <div class="nexus-plan-row">
                                  <div>
                                    <strong>{plan.name}</strong>
                                    <span>{plan.detail}</span>
                                  </div>
                                  <div>
                                    <strong>{plan.value}</strong>
                                    {plan.badge && <small>{plan.badge}</small>}
                                  </div>
                                </div>
                              ))}
                            </div>
                            <div class="nexus-benefits-card__footer">
                              <span>{feature.contributionLabel}</span>
                              <strong>{feature.contributionValue}</strong>
                            </div>
                          </div>
                        )}

                        {'fields' in feature && feature.fields && (
                          <div class="nexus-offer-card">
                            <div class="nexus-offer-card__grid">
                              {feature.fields.map((field) => (
                                <div>
                                  <span>{field.label}</span>
                                  <strong>{field.value}</strong>
                                </div>
                              ))}
                            </div>
                            <div class="nexus-offer-card__actions">
                              <button class="nexus-button nexus-button--danger" type="button">{feature.primary}</button>
                              <button class="nexus-button nexus-button--secondary" type="button">{feature.secondary}</button>
                            </div>
                          </div>
                        )}

                        {'messages' in feature && feature.messages && (
                          <div class="nexus-slack-card">
                            {feature.messages.map((message) => (
                              <div class="nexus-message-row">
                                <span class={`nexus-message-row__avatar ${message.accent ? 'is-accent' : ''}`.trim()}>{message.initial}</span>
                                <div>
                                  <div class="nexus-message-row__meta">
                                    <strong>{message.author}</strong>
                                    <span>{message.time}</span>
                                  </div>
                                  <p>{message.text}</p>
                                </div>
                              </div>
                            ))}
                          </div>
                        )}
                      </article>
                    </section>
                  ))}
                </section>

                <section class="nexus-testimonials" id="nexus-testimonials">
                  <div class="nexus-section-heading nexus-section-heading--center">
                    <h2>
                      <span>{nexusPreview.trustTitleLeading}</span>
                      <span>{nexusPreview.trustTitleAccent}</span>
                    </h2>
                  </div>
                  <div class="nexus-testimonials__grid">
                    {nexusPreview.testimonials.map((item) => (
                      <article class="nexus-testimonial-card">
                        <span>{item.tag}</span>
                        <p>{item.quote}</p>
                        <div class="nexus-testimonial-card__author">
                          <strong>{item.initials}</strong>
                          <div>
                            <b>{item.author}</b>
                            <small>{item.role}</small>
                          </div>
                        </div>
                      </article>
                    ))}
                  </div>
                </section>

                <section class="nexus-onboard" id="nexus-onboard">
                  <div class="nexus-onboard__copy">
                    <h2>
                      <span>{nexusPreview.onboarding.titleLeading}</span>
                      <span>{nexusPreview.onboarding.titleAccent}</span>
                      <span>{nexusPreview.onboarding.titleTail}</span>
                    </h2>
                    <div class="nexus-step-list">
                      {nexusPreview.onboarding.steps.map((item) => (
                        <article class="nexus-step-row">
                          <span>{item.index}</span>
                          <div>
                            <h3>{item.title}</h3>
                            <p>{item.description}</p>
                          </div>
                        </article>
                      ))}
                    </div>
                  </div>

                  <article class="nexus-setup-card">
                    <span>{nexusPreview.onboarding.setupTitle}</span>
                    <div class="nexus-setup-card__grid">
                      {nexusPreview.onboarding.fields.map((field) => (
                        <div>
                          <p>{field.label}</p>
                          <strong>{field.value}</strong>
                        </div>
                      ))}
                    </div>
                    <button class="nexus-button nexus-button--danger" type="button">{nexusPreview.onboarding.cta}</button>
                  </article>
                </section>

                <section class="nexus-support" id="nexus-support">
                  {nexusPreview.supportCards.map((item) => (
                    <article class="nexus-support-card">
                      <span class="nexus-support-card__icon" aria-hidden="true"></span>
                      <h3>{item.title}</h3>
                      <p>{item.description}</p>
                      <small>{item.meta}</small>
                    </article>
                  ))}
                </section>

                <section class="nexus-closing" id="get-started">
                  <h2>{nexusPreview.closingTitle}</h2>
                  <div class="nexus-closing__actions">
                    <a class="nexus-button nexus-button--primary" href={remixHref}>{nexusPreview.closingPrimary}</a>
                    <button class="nexus-button nexus-button--secondary" type="button">{nexusPreview.closingSecondary}</button>
                  </div>
                </section>

                <footer class="nexus-footer">
                  <div class="nexus-footer__top">
                    <div class="nexus-footer__brand">
                      <div class="nexus-brand">
                        <span class="nexus-brand__mark">{nexusPreview.brand.mark}</span>
                        <span>{nexusPreview.brand.name}</span>
                      </div>
                      <p>{nexusPreview.footerTagline}</p>
                    </div>
                    <div class="nexus-footer__columns">
                      {nexusPreview.footerColumns.map((column) => (
                        <div>
                          <h4>{column.title}</h4>
                          <ul>
                            {column.links.map((item) => (
                              <li><a href="#">{item}</a></li>
                            ))}
                          </ul>
                        </div>
                      ))}
                    </div>
                  </div>
                  <div class="nexus-footer__bottom">
                    <p>{nexusPreview.footerCopy}</p>
                    <div>
                      {nexusPreview.footerSocial.map((item) => (
                        <a href="#">{item}</a>
                      ))}
                    </div>
                  </div>
                </footer>

                <div class="nexus-marquee" aria-hidden="true">
                  {Array.from({ length: 6 }).map(() => (
                    <span>{nexusPreview.marqueeLabel}</span>
                  ))}
                </div>

                <a class="nexus-built-with" href="https://www.superun.com">
                  <span>Built with</span>
                  <strong>superun</strong>
                  <span aria-hidden="true">×</span>
                </a>
              </article>
            ) : iframePreviewSrc ? (
              <div class="community-iframe-host" data-iframe-host>
                <div class="community-iframe-loader" data-iframe-loader>
                  <div class="community-iframe-loader__pulse" aria-hidden="true"></div>
                </div>
                <iframe
                  class="community-iframe"
                  id="community-preview-iframe"
                  src={iframePreviewSrc}
                  title={template.title}
                  loading="eager"
                  referrerpolicy="no-referrer"
                ></iframe>
              </div>
            ) : media ? (
              <img class="community-preview-fallback" src={media.image} alt={template.title} loading="eager" decoding="async" />
            ) : null}
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ locales }}>
    (() => {
      const currentDevice = new URL(window.location.href).searchParams.get('device');
      const previewFrame = document.querySelector('#preview-frame');
      const previewIframe = document.querySelector('#community-preview-iframe');
      const iframeHost = document.querySelector('[data-iframe-host]');
      const iframeLoader = document.querySelector('[data-iframe-loader]');
      const toggleButtons = Array.from(document.querySelectorAll('[data-device-toggle]'));
      const copy = JSON.parse(locales);
      const localeAliases = {
        'zh-CN': 'zh-CN',
        'zh-TW': 'zh-CN',
        yue: 'zh-CN',
        ja: 'zh-CN',
        ko: 'zh-CN',
        en: 'en',
        global: 'en',
      };

      const applyCopy = (locale) => {
        const nextLocale = localeAliases[locale] || 'zh-CN';
        const nextCopy = copy[nextLocale] || copy['zh-CN'];
        document.querySelectorAll('[data-copy-key]').forEach((node) => {
          const key = node.getAttribute('data-copy-key');
          if (!key) return;
          const [scope, field] = key.split('.');
          const value = nextCopy?.[scope]?.[field];
          if (typeof value === 'string') node.textContent = value;
        });
        document.querySelectorAll('[data-copy-aria]').forEach((node) => {
          const key = node.getAttribute('data-copy-aria');
          if (!key) return;
          const [scope, field] = key.split('.');
          const value = nextCopy?.[scope]?.[field];
          if (typeof value === 'string') node.setAttribute('aria-label', value);
        });
      };

      const applyDevice = (device) => {
        const isMobile = device === 'mobile';
        previewFrame?.classList.toggle('is-mobile', isMobile);
        iframeHost?.classList.toggle('is-mobile', isMobile);
        if (previewIframe instanceof HTMLIFrameElement) {
          previewIframe.dataset.device = isMobile ? 'mobile' : 'desktop';
        }
        toggleButtons.forEach((button) => {
          const active = button.getAttribute('data-device-toggle') === device;
          button.classList.toggle('is-active', active);
        });
        const nextUrl = new URL(window.location.href);
        if (isMobile) nextUrl.searchParams.set('device', 'mobile');
        else nextUrl.searchParams.delete('device');
        window.history.replaceState({}, '', `${nextUrl.pathname}${nextUrl.search}${nextUrl.hash}`);
      };

      applyCopy(document.documentElement.dataset.publicLocale || 'zh-CN');
      applyDevice(currentDevice === 'mobile' ? 'mobile' : 'desktop');

      toggleButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const device = button.getAttribute('data-device-toggle') === 'mobile' ? 'mobile' : 'desktop';
          applyDevice(device);
        });
      });

      if (previewIframe instanceof HTMLIFrameElement && iframeLoader instanceof HTMLElement) {
        const hideLoader = () => {
          iframeLoader.setAttribute('hidden', '');
          iframeHost?.classList.add('is-ready');
        };
        previewIframe.addEventListener('load', hideLoader, { once: true });
      }

      window.addEventListener('public-locale-change', (event) => {
        const locale = event.detail?.locale || 'zh-CN';
        applyCopy(locale);
      });
    })();
  </script>
</BaseLayout>
