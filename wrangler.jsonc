{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "superun-public-site",
  "main": "src/worker.ts",
  "compatibility_date": "2026-03-25",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "html_handling": "drop-trailing-slash",
    "not_found_handling": "404-page",
    "run_worker_first": true
  }
}
